# Reference only. `pnpm setup` writes real local secrets to ignored .local/development.env.
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
WEB_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+psycopg://shadowgrid:use-a-local-secret@localhost:5432/shadowgrid
REDIS_URL=redis://localhost:6379/0
SMTP_HOST=localhost
SMTP_PORT=1025
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=shadowgrid
ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=30
SEASON_DAYS=14
TRANSLATION_PROVIDER=disabled
ALLOW_EXTERNAL_DEPLOY=false
