APP_ENV=production
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
SECRET_KEY=generate-in-provider-secret-store
REFRESH_PEPPER=generate-in-provider-secret-store
SEED_SECRET=generate-in-provider-secret-store
WEB_ORIGINS=https://your-web-host.example
SMTP_HOST=your-smtp-host.example
SMTP_PORT=587
ACCESS_TOKEN_MINUTES=10
REFRESH_TOKEN_DAYS=30
TRANSLATION_PROVIDER=disabled
