{
  "expo": {
    "name": "SHADOWGRID",
    "slug": "shadowgrid",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "shadowgrid",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": { "image": "./assets/splash.png", "resizeMode": "contain", "backgroundColor": "#080a0d" },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "game.shadowgrid.mobile",
      "associatedDomains": ["applinks:app.shadowgrid.example"],
      "infoPlist": { "ITSAppUsesNonExemptEncryption": false },
      "privacyManifests": { "NSPrivacyAccessedAPITypes": [] }
    },
    "android": {
      "package": "game.shadowgrid.mobile",
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#080a0d" },
      "intentFilters": [{ "action": "VIEW", "autoVerify": true, "data": [{ "scheme": "https", "host": "app.shadowgrid.example", "pathPrefix": "/open" }], "category": ["BROWSABLE", "DEFAULT"] }]
    },
    "web": { "bundler": "metro", "output": "static", "favicon": "./assets/favicon.png" },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": { "typedRoutes": true },
    "extra": { "router": { "origin": false }, "apiUrl": "http://localhost:8000/api/v1", "eas": { "projectId": "00000000-0000-0000-0000-000000000000" } }
  }
}
