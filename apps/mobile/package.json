{
  "name": "@shadowgrid/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "lint": "eslint app src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --coverage",
    "format:check": "prettier --check app src"
  },
  "dependencies": {
    "@expo/metro-runtime": "5.0.5",
    "@shadowgrid/api-client": "workspace:*",
    "@shadowgrid/game-config": "workspace:*",
    "@shadowgrid/i18n": "workspace:*",
    "@shadowgrid/shared-types": "workspace:*",
    "@tanstack/react-query": "5.80.7",
    "expo": "53.0.27",
    "expo-constants": "17.1.8",
    "expo-linking": "7.1.7",
    "expo-router": "5.1.11",
    "expo-secure-store": "14.2.4",
    "expo-splash-screen": "0.30.10",
    "expo-status-bar": "2.2.3",
    "i18next": "25.2.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "15.5.3",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "4.11.1",
    "react-native-web": "0.20.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [],
    "testMatch": [
      "<rootDir>/src/**/*.test.ts?(x)"
    ],
    "collectCoverageFrom": [
      "<rootDir>/src/theme.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "19.0.14",
    "eslint": "9.29.0",
    "eslint-config-expo": "9.2.0",
    "jest": "29.7.0",
    "jest-expo": "53.0.14",
    "prettier": "3.5.3",
    "typescript": "5.8.3"
  }
}
